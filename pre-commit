#!/usr/bin/env python3
"""Git pre-commit hook that scans staged files."""

from __future__ import annotations

from pathlib import Path
import subprocess
import sys


def load_validator():
    script_path = Path(__file__).resolve()
    for candidate in script_path.parents:
        validator_path = candidate / "validator.py"
        if validator_path.is_file():
            sys.path.insert(0, str(candidate))
            from validator import run_pre_commit_checks  # pylint: disable=import-outside-toplevel

            return run_pre_commit_checks

    raise RuntimeError("Could not locate validator.py from the hook script.")


def main() -> int:
    run_pre_commit_checks = load_validator()

    try:
        report = run_pre_commit_checks()
    except subprocess.CalledProcessError as exc:
        stderr = exc.stderr.decode("utf-8", errors="replace").strip()
        print("Pre-commit check failed because Git could not read staged files.")
        if stderr:
            print(stderr)
        return 1

    if report.warnings:
        print("Pre-commit warnings:")
        for warning in report.warnings:
            print(f"- {warning}")

    if report.errors:
        print("Commit rejected due to pre-commit errors:")
        for error in report.errors:
            print(f"- {error}")
        return 1

    return 0


if __name__ == "__main__":
    raise SystemExit(main())
